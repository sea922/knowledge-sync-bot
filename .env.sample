OPENAI_API_KEY=sk-...

# Optional — if left blank, a new Vector Store will be created automatically
# and its ID will be saved to state/resources.json for reuse on subsequent runs.
VECTOR_STORE_ID=

# Optional — if left blank, a new Assistant will be created automatically
# and its ID will be saved to state/resources.json for reuse on subsequent runs.
ASSISTANT_ID=

# ---------------------------------------------------------------------------
# Observability (optional)
# Leave blank or unset to disable metrics push — pipeline runs normally.
# ---------------------------------------------------------------------------

# URL of the Prometheus Pushgateway (local dev: http://localhost:9091)
PUSHGATEWAY_URL=http://localhost:9091
