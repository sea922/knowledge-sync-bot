# Your OpenAI secret key — get it from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ID of the Vector Store created in the OpenAI Dashboard (Platform > Storage > Vector Stores)
# The upload script will attach scraped markdown files to this store.
VECTOR_STORE_ID=vs_...

# ID of the Assistant created in the OpenAI Playground (Platform > Assistants)
# This is the OptiBot clone that answers user questions using the vector store.
ASSISTANT_ID=asst_...

# ---------------------------------------------------------------------------
# Observability (optional)
# Leave blank or unset to disable metrics push — pipeline runs normally.
# ---------------------------------------------------------------------------

# URL of the Prometheus Pushgateway (local dev: http://localhost:9091)
# On DigitalOcean, point this to your Droplet: http://<droplet-ip>:9091
PUSHGATEWAY_URL=http://localhost:9091
